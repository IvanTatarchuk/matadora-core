{
  "version": 2,
  "builds": [
    {
      "src": "api/ping.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": "backend/**"
      }
    }
  ],
  "routes": [
    { "src": "/api/ping", "dest": "api/ping.py" },
    { "src": "/(.*)", "dest": "api/index.py" }
  ]
}
